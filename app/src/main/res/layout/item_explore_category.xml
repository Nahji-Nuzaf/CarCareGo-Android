<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#1A222E"
    app:cardCornerRadius="20dp"
    app:strokeColor="@color/brand_sapphire_blue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/home_24px"
            app:tint="@color/brand_sapphire_blue" />

        <TextView
            android:id="@+id/tvCategoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Home Wash"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvCategorySub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We come to you"
            android:textAlignment="center"
            android:textColor="@color/text_slate_gray"
            android:textSize="11sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>