<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_navy_dark">

    <RelativeLayout
        android:id="@+id/rlAddressHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackAddAddress"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@drawable/circle_button_bg"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Manage Address"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnSaveAddress"
        app:layout_constraintTop_toBottomOf="@id/rlAddressHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address (Line 01)"
                android:textSize="18dp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etAddressName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/custom_input_search_polished"
                android:hint="Your Address"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_slate_gray"
                android:textCursorDrawable="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Address Line 02"
                android:textSize="18dp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etAddressLine02"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/custom_input_search_polished"
                android:hint="Apartment, suite, etc. (Optional)"
                android:inputType="textPostalAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_slate_gray"
                android:textCursorDrawable="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="City"
                android:textSize="18dp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etCity"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/custom_input_search_polished"
                android:hint="e.g. Colombo or Dehiwala"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_slate_gray"
                android:textCursorDrawable="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Postal Code"
                android:textSize="18dp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etPostalCode"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/custom_input_search_polished"
                android:hint="e.g. 10350"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_slate_gray"
                android:textCursorDrawable="@null"/>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveAddress"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="24dp"
        android:text="Save"
        android:textAllCaps="false"
        app:backgroundTint="@color/brand_sapphire_blue"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>