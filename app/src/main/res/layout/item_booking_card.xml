<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#1A222E"
    app:cardCornerRadius="20dp"
    app:strokeColor="#334155"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_bg_light"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Order Completed"
            android:textColor="@color/brand_sapphire_blue"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivServicePic"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:src="#334155"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBadge"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/badge_bg_light"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Car Washing Service"
            android:textColor="@color/text_slate_gray"
            android:textSize="10sp"
            app:layout_constraintStart_toEndOf="@id/ivServicePic"
            app:layout_constraintTop_toTopOf="@id/ivServicePic" />

        <TextView
            android:id="@+id/tvStudioName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="MajesticShine Car Hub"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvCategory"
            app:layout_constraintTop_toBottomOf="@id/tvCategory" />

        <LinearLayout
            android:id="@+id/layoutDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivServicePic">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order ID" android:textColor="@color/text_slate_gray" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#CRR0211AA3" android:textColor="@color/white" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order Date" android:textColor="@color/text_slate_gray" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25 Dec" android:textColor="@color/white" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Payment" android:textColor="@color/text_slate_gray" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$68.00" android:textColor="@color/brand_sapphire_blue" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/layoutDetails">

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Leave Review"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#334155"
                app:cornerRadius="24dp"
                android:textAllCaps="false"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="E-Receipt"
                app:backgroundTint="@color/brand_sapphire_blue"
                app:cornerRadius="24dp"
                android:textAllCaps="false"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>