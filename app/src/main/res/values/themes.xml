<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CarCareGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_sapphire_blue</item>
        <item name="colorPrimaryVariant">@color/brand_sapphire_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/brand_navy_surface</item>
        <item name="colorSecondaryVariant">@color/brand_navy_dark</item>
        <item name="colorOnSecondary">@color/text_ghost_white</item>

        <item name="android:statusBarColor">@color/brand_navy_dark</item>
        <item name="android:windowBackground">@color/brand_navy_dark</item>

        <item name="colorSurface">@color/brand_navy_surface</item>
        <item name="colorOnSurface">@color/text_ghost_white</item>

<!--        <item name="colorControlActivated">@color/brand_sapphire_blue</item>-->
<!--        <item name="colorAccent">@color/brand_sapphire_blue</item>-->

    </style>

    <style name="Theme.CarCareGo.FullScreen" parent="Theme.CarCareGo">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="RoundedTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">25dp</item>
        <item name="boxCornerRadiusTopEnd">25dp</item>
        <item name="boxCornerRadiusBottomStart">25dp</item>
        <item name="boxCornerRadiusBottomEnd">25dp</item>

        <item name="boxBackgroundColor">#1A222E</item>

        <item name="boxStrokeColor">@color/brand_sapphire_blue</item>
        <item name="android:textColorHint">#94A3B8</item> </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TopRoundedCorner">
        <item name="cornerSizeTopLeft">30dp</item>
        <item name="cornerSizeTopRight">30dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="CustomCalendar" parent="android:Widget.CalendarView">
        <item name="android:focusedMonthDateColor">@color/white</item>
        <item name="android:unfocusedMonthDateColor">#94A3B8</item>
        <item name="android:selectedWeekBackgroundColor">@color/brand_sapphire_blue</item>
        <item name="android:weekSeparatorLineColor">@android:color/transparent</item>
    </style>

    <style name="LightCalendarTheme" parent="Theme.AppCompat.Light">
        <item name="android:textColorPrimary">#1A222E</item>
        <item name="android:textColorSecondary">#475569</item>
        <item name="android:colorAccent">@color/brand_sapphire_blue</item>
    </style>

    <style name="TabTextSelection" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="RoundedImage8">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>